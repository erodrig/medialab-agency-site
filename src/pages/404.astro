---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - MediaLab">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-black text-brand-accent mb-4">404</h1>
      <p class="text-xl text-brand-gray mb-8">Pagina no encontrada</p>
      <a href="/" class="inline-block bg-brand-accent text-white px-8 py-3 text-sm font-semibold uppercase tracking-wider rounded hover:bg-red-700 transition-colors">
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>

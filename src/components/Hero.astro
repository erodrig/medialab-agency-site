---
const slides = [
  '/images/hero/slide1.png',
  '/images/hero/slide2.png',
  '/images/hero/slide3.png',
  '/images/hero/slide4.png',
  '/images/hero/slide5.png',
  '/images/hero/slide6.png',
];
---

<!-- Hero with video -->
<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-brand-black">
  <div class="absolute inset-0">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover opacity-60"
    >
      <source src="/images/hero/hero-video.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <div class="relative z-10 text-center px-6">
    <img
      src="/images/logo/ml-logo.png"
      alt="Media Lab Agency"
      class="mx-auto w-[300px] md:w-[500px] mb-8"
    />
  </div>
</section>

<!-- WE LOVE CREATORS marquee -->
<div class="bg-brand-black overflow-hidden py-3">
  <div class="we-love-marquee flex whitespace-nowrap text-white">
    <span class="marquee-text text-2xl md:text-4xl font-black uppercase tracking-wider px-4">WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;</span>
    <span class="marquee-text text-2xl md:text-4xl font-black uppercase tracking-wider px-4">WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;WE <span class="text-[#ffd700]">&hearts;</span> CREATORS&nbsp;&nbsp;&nbsp;</span>
  </div>
</div>

<!-- Estrategia carousel section -->
<section class="relative overflow-hidden bg-brand-black" style="background-image: url('/images/hero/fondo.png'); background-size: cover; background-position: center;">
  <div class="relative z-10">
    <!-- Carousel -->
    <div class="carousel relative w-full" style="min-height: 80vh;">
      {slides.map((slide, i) => (
        <div
          class:list={['carousel-slide absolute inset-0 transition-opacity duration-700', i === 0 ? 'opacity-100' : 'opacity-0']}
          data-index={i}
        >
          <img
            src={slide}
            alt={`Slide ${i + 1}`}
            class="w-full h-full object-contain"
          />
        </div>
      ))}

      <!-- Nav arrows -->
      <button class="carousel-prev absolute left-4 top-1/2 -translate-y-1/2 z-20 text-white text-4xl hover:text-brand-accent transition-colors" aria-label="Previous slide">
        &#8249;
      </button>
      <button class="carousel-next absolute right-4 top-1/2 -translate-y-1/2 z-20 text-white text-4xl hover:text-brand-accent transition-colors" aria-label="Next slide">
        &#8250;
      </button>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.carousel-slide');
  const prevBtn = document.querySelector('.carousel-prev');
  const nextBtn = document.querySelector('.carousel-next');
  let current = 0;
  const total = slides.length;

  function showSlide(index: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('opacity-100', i === index);
      (s as HTMLElement).classList.toggle('opacity-0', i !== index);
    });
    current = index;
  }

  prevBtn?.addEventListener('click', () => {
    showSlide((current - 1 + total) % total);
  });

  nextBtn?.addEventListener('click', () => {
    showSlide((current + 1) % total);
  });

  // Auto-advance every 5 seconds
  setInterval(() => {
    showSlide((current + 1) % total);
  }, 5000);
</script>

<style>
  .we-love-marquee {
    animation: we-love-scroll 15s linear infinite;
  }

  @keyframes we-love-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

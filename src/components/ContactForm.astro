---
// Set the API Gateway URL after deploying AgencyContactStack
const apiUrl = import.meta.env.PUBLIC_CONTACT_API_URL || '';
---

<section id="contacto" class="py-24 bg-brand-black">
  <div class="max-w-2xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 uppercase tracking-wider">
      Contacto
    </h2>

    <form id="contact-form" class="space-y-6">
      <div>
        <input
          type="text"
          name="name"
          placeholder="Nombre"
          required
          class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white placeholder-brand-gray focus:outline-none focus:border-brand-accent transition-colors"
        />
      </div>
      <div>
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white placeholder-brand-gray focus:outline-none focus:border-brand-accent transition-colors"
        />
      </div>
      <div>
        <textarea
          name="message"
          placeholder="Mensaje"
          rows="5"
          required
          class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white placeholder-brand-gray focus:outline-none focus:border-brand-accent transition-colors resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full bg-brand-accent text-white py-4 text-sm font-semibold uppercase tracking-wider rounded hover:bg-red-700 transition-colors"
      >
        Enviar
      </button>
      <p id="form-status" class="text-center text-sm hidden"></p>
    </form>
  </div>
</section>

<script define:vars={{ apiUrl }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    if (!apiUrl) {
      // Fallback to mailto if API not configured
      window.location.href = `mailto:hello@medialab.agency?subject=Contacto desde web - ${data.name}&body=${data.message}`;
      return;
    }

    const btn = form.querySelector('button');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch(`${apiUrl}/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        status.textContent = 'Mensaje enviado. Gracias!';
        status.className = 'text-center text-sm text-green-400';
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch {
      status.textContent = 'Error al enviar. Intenta de nuevo.';
      status.className = 'text-center text-sm text-red-400';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar';
      status.classList.remove('hidden');
    }
  });
</script>

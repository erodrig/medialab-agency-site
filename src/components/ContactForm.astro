---
const apiUrl = import.meta.env.PUBLIC_CONTACT_API_URL || '';
---

<section id="contacto" class="py-24 bg-brand-black">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <!-- Contact Form -->
      <div class="flex-1 w-full">
        <form id="contact-form" class="space-y-4">
          <div>
            <label class="block text-xs font-medium uppercase tracking-wider mb-1">Nombre *</label>
            <input
              type="text"
              name="name"
              required
              class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white focus:outline-none focus:border-brand-accent transition-colors"
            />
          </div>
          <div>
            <label class="block text-xs font-medium uppercase tracking-wider mb-1">E-mail *</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white focus:outline-none focus:border-brand-accent transition-colors"
            />
          </div>
          <div>
            <label class="block text-xs font-medium uppercase tracking-wider mb-1">Mensaje *</label>
            <textarea
              name="message"
              rows="4"
              required
              class="w-full bg-brand-dark border border-gray-700 rounded px-4 py-3 text-white focus:outline-none focus:border-brand-accent transition-colors resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-brand-accent text-white px-8 py-3 text-sm font-semibold uppercase tracking-wider rounded hover:bg-red-700 transition-colors"
          >
            Enviar
          </button>
          <p id="form-status" class="text-center text-sm hidden"></p>
        </form>
      </div>

      <!-- CTA Heading -->
      <div class="flex-1 text-center md:text-left">
        <h2 class="text-3xl md:text-5xl font-black uppercase tracking-wider leading-tight text-brand-accent">
          Empieza hoy mismo tu campana con influencers
        </h2>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ apiUrl }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    if (!apiUrl) {
      window.location.href = `mailto:hello@medialab.agency?subject=Contacto desde web - ${data.name}&body=${data.message}`;
      return;
    }

    const btn = form.querySelector('button');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch(`${apiUrl}/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        status.textContent = 'Mensaje enviado. Gracias!';
        status.className = 'text-center text-sm text-green-400';
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch {
      status.textContent = 'Error al enviar. Intenta de nuevo.';
      status.className = 'text-center text-sm text-red-400';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar';
      status.classList.remove('hidden');
    }
  });
</script>

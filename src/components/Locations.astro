---
const locations = [
  { city: 'Ciudad de México, México', address: 'Salamanca 34, Planta Baja. Roma Norte' },
  { city: 'Santiago, Chile', address: 'Triana 857, Of 13. Providencia' },
  { city: 'Buenos Aires, Argentina', address: 'Fondo de la Legua 936, Piso 2. San Isidro' },
  { city: 'Bogotá, Colombia', address: 'Carrera 112F #80-59, Bogotá DC' },
  { city: 'Montevideo, Uruguay', address: 'Esteban Elena 6405 Oficina 6' },
  { city: 'Lima, Perú', address: 'Calle Monte Rosa Nº 255 Oficina 601' },
  { city: 'Quito, Ecuador', address: 'Avenida Francisco de Orellana E2-30' },
];
---

<section class="py-24 bg-white text-black">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-16 uppercase tracking-wider text-brand-accent">
      con presencia en
    </h2>

    <div class="flex flex-col md:flex-row gap-12 items-start">
      <!-- Locations list -->
      <div class="flex-1 space-y-6">
        {locations.map((loc) => (
          <div>
            <h5 class="text-sm font-bold uppercase tracking-wider">{loc.city}</h5>
            <p class="text-xs text-gray-600 uppercase tracking-wider mt-1">{loc.address}</p>
          </div>
        ))}
      </div>

      <!-- Map -->
      <div class="flex-1">
        <img
          src="/images/locations/map.webp"
          alt="Mapa de oficinas en Latinoamérica"
          class="w-full max-w-[500px] mx-auto h-auto"
        />
      </div>
    </div>
  </div>
</section>

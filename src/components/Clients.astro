---
// Add client logo filenames to public/images/clients/ and list them here
const clients: string[] = [
  // 'client1.png',
  // 'client2.png',
];
---

<section class="py-24 bg-brand-black">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 uppercase tracking-wider">
      Nuestros Clientes
    </h2>

    {clients.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8 items-center justify-items-center">
        {clients.map((logo) => (
          <img
            src={`/images/clients/${logo}`}
            alt="Cliente"
            class="h-12 object-contain opacity-70 hover:opacity-100 transition-opacity grayscale hover:grayscale-0"
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-brand-gray">Logos de clientes por agregar</p>
    )}
  </div>
</section>

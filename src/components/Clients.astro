---
const clientRows = [
  { src: '/images/clients/clients-row-2.png', direction: 'right' },
  { src: '/images/clients/clients-row-3.png', direction: 'left' },
  { src: '/images/clients/clients-row-4.png', direction: 'right' },
];
---

<section class="relative py-24 bg-brand-black overflow-hidden">
  <img
    src="/images/hero/fondo.png"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-30"
  />
  <div class="relative z-10">
    <h2 class="text-4xl md:text-6xl lg:text-7xl font-black text-center mb-12 uppercase tracking-wider text-white">
      Nuestros clientes
    </h2>

    <div class="space-y-4">
      {clientRows.map((row) => (
        <div class="marquee-container overflow-hidden">
          <div class:list={['marquee-track flex gap-0', row.direction === 'right' ? 'marquee-right' : 'marquee-left']}>
            <img src={row.src} alt="Clientes" class="h-[50px] md:h-[70px] w-auto object-contain flex-shrink-0" />
            <img src={row.src} alt="Clientes" class="h-[50px] md:h-[70px] w-auto object-contain flex-shrink-0" />
            <img src={row.src} alt="Clientes" class="h-[50px] md:h-[70px] w-auto object-contain flex-shrink-0" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    will-change: transform;
  }

  .marquee-left {
    animation: marquee-left 30s linear infinite;
  }

  .marquee-right {
    animation: marquee-right 30s linear infinite;
  }

  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }

  @keyframes marquee-right {
    0% {
      transform: translateX(-33.333%);
    }
    100% {
      transform: translateX(0);
    }
  }
</style>

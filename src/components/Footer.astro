  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <a href="/" class="text-xl font-bold tracking-tight">MEDIALAB</a>

    <div class="flex items-center gap-6">
      <a href="#contacto" class="text-sm text-brand-gray hover:text-white transition-colors uppercase tracking-wider">
        Contacto
      </a>
      <a href="https://www.instagram.com/medialab.agency/" target="_blank" rel="noopener" class="text-brand-gray hover:text-white transition-colors">
        Instagram
      </a>
      <a href="https://www.linkedin.com/company/medialab-agency/" target="_blank" rel="noopener" class="text-brand-gray hover:text-white transition-colors">
        LinkedIn
      </a>
    </div>


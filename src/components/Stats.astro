---
const stats = [
  { value: 50, suffix: '+', label: 'Empleados' },
  { value: 500, suffix: '+', label: 'Creadores' },
  { value: 100, suffix: '+', label: 'Proyectos mensuales' },
];
---

<section class="py-24 bg-brand-dark">
  <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
    {stats.map((stat) => (
      <div>
        <div
          class="text-5xl md:text-6xl font-black text-brand-accent counter"
          data-target={stat.value}
          data-suffix={stat.suffix}
        >
          0{stat.suffix}
        </div>
        <p class="mt-3 text-brand-gray text-lg uppercase tracking-wider">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<script>
  const counters = document.querySelectorAll('.counter');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const suffix = el.dataset.suffix || '';
        let current = 0;
        const step = Math.max(1, Math.floor(target / 60));
        const interval = setInterval(() => {
          current += step;
          if (current >= target) {
            current = target;
            clearInterval(interval);
          }
          el.textContent = `${current}${suffix}`;
        }, 20);
        observer.unobserve(el);
      });
    },
    { threshold: 0.5 },
  );

  counters.forEach((c) => observer.observe(c));
</script>
